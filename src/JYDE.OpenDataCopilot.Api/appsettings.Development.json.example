{
  "// NOTA": "Copia este archivo como appsettings.Development.json (gitignored) y pon tu cadena real. NO commitees secretos.",
  "Providers": {
    "CatalogRepository": "Mongo",
    "SearchIndex": "Mongo",
    "Embeddings": "Local",
    "Chat": "Foundry"
  },
  "Mongo": {
    "ConnectionString": "mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/?appName=<app>",
    "Database": "odc_BD"
  },
  "// Foundry": "Endpoint del proyecto de Foundry + api-key. NO commitees la clave (este archivo está gitignored).",
  "Foundry": {
    "Endpoint": "https://<recurso>.services.ai.azure.com/api/projects/<proyecto>",
    "ApiKey": "<clave>",
    "Chat": {
      "Model": "gpt-4o-mini",
      "Agents": {
        "dataset-recommender-agent": { "Name": "dataset-recommender-agent", "Version": "1" }
      }
    },
    "Embeddings": {
      "Deployment": "text-embedding-3-small",
      "ApiVersion": "2024-02-01",
      "Dimensions": 1536
    }
  }
}
