{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Providers": {
    "CatalogRepository": "InMemory",
    "SearchIndex": "InMemory",
    "Embeddings": "Local",
    "Chat": "Fake"
  },
  "Socrata": {
    "BaseAddress": "https://www.datos.gov.co",
    "PageSize": 1000,
    "TimeoutSeconds": 30
  },
  "Mongo": {
    "ConnectionString": "",
    "Database": "odc_BD",
    "CatalogCollection": "datasets"
  },
  "Conversation": {
    "RouterAgent": "router-agent",
    "CategoryRelevanceThreshold": 0.5
  },
  "Foundry": {
    "Endpoint": "",
    "ApiKey": "",
    "Chat": {
      "Model": "gpt-4o-mini",
      "Agents": {
        "router-agent": { "Name": "router-agent", "Version": "3", "Model": "gpt-4o-mini" },
        "dataset-recommender-agent": { "Name": "dataset-recommender-agent", "Version": "5", "Model": "gpt-4.1-mini" },
        "dataset-analyst-agent": { "Name": "dataset-analyst-agent", "Version": "1", "Model": "gpt-4.1-mini" },
        "category-recommender-agent": { "Name": "category-recommender-agent", "Version": "2", "Model": "gpt-4o-mini" }
      }
    },
    "Embeddings": {
      "Deployment": "text-embedding-3-small",
      "ApiVersion": "2024-02-01",
      "Dimensions": 256
    }
  }
}
